<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddToursActivity"
    android:orientation="vertical"
    android:background="@drawable/tours">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Eco Tour"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- Tour Name -->
        <EditText
            android:id="@+id/tourNameTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tour Name"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp" />

        <!-- Duration -->
        <EditText
            android:id="@+id/durationTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Duration (hours)"
            android:inputType="number"
            android:layout_marginBottom="12dp" />

        <!-- Difficulty Spinner -->
        <Spinner
            android:id="@+id/difficultySpn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Facilities -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Facilities"
            android:textStyle="bold"
            android:layout_marginTop="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <CheckBox
                android:id="@+id/transportChk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transport" />

            <CheckBox
                android:id="@+id/mealsChk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meals"
                android:layout_marginLeft="15dp" />

            <CheckBox
                android:id="@+id/guideChk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guide"
                android:layout_marginLeft="15dp" />
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/addTourBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Tour" />

            <Button
                android:id="@+id/cancelTourBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:layout_marginLeft="20dp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
