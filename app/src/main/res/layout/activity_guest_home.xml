<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="GuestHomeActivity"
    android:orientation="vertical"
    android:background="@drawable/dd">


    <!-- Header -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="40dp"
        android:layout_gravity="center">

        <TextView
            android:id="@+id/textView3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="36sp"
            android:text="EcoStay Retreat"
            android:textColor="#2E7D32"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guest Home"
        android:textSize="24sp"
        android:textColor="#666666"
        android:layout_gravity="center"
        android:layout_marginTop="16dp" />

    <!-- Book Room Button -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="40dp"
        android:layout_gravity="center">

        <Button
            android:id="@+id/bookroombtn"
            android:layout_width="300dp"
            android:layout_height="60dp"
            android:textSize="20sp"
            android:text="Book Room"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Book Hiking Button -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="30dp"
        android:layout_gravity="center">

        <Button
            android:id="@+id/bookhikisbtn"
            android:layout_width="300dp"
            android:layout_height="60dp"
            android:textSize="20sp"
            android:text="Book Hiking"

            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Book Birdwatching Button -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="30dp"
        android:layout_gravity="center">

        <Button
            android:id="@+id/bookbirdbtn"
            android:layout_width="300dp"
            android:layout_height="60dp"
            android:textSize="18sp"
            android:text="Book Birdwatching"

            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Book Tours Button -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="30dp"
        android:layout_gravity="center">

        <Button
            android:id="@+id/booktoursbtn"
            android:layout_width="300dp"
            android:layout_height="60dp"
            android:textSize="20sp"
            android:text="Book Eco Tours"

            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>



    <!-- Logout Button -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="50dp"
        android:layout_gravity="center">

        <Button
            android:id="@+id/logoutbtn"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:textSize="18sp"
            android:text="Logout"

            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>