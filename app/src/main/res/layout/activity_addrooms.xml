<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddRoomsActivity"
    android:orientation="vertical"
    android:background="@drawable/room">

    <TextView
        android:id="@+id/textView9"
        android:layout_marginTop="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:text="Add Rooms "
        android:textSize="50dp"
        tools:layout_editor_absoluteX="56dp"
        tools:layout_editor_absoluteY="60dp" />
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/textView8"
            android:layout_marginTop="20dp"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Room No   "
            android:textSize="30dp"
            tools:layout_editor_absoluteX="56dp"
            tools:layout_editor_absoluteY="60dp" />

        <EditText
            android:layout_marginTop="10dp"
            android:id="@+id/roomNotxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ems="10"
            android:inputType="text"
            android:text="" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/textView6"
            android:layout_marginTop="20dp"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Room Type"
            android:textSize="30dp"
            tools:layout_editor_absoluteX="56dp"
            tools:layout_editor_absoluteY="60dp" />

        <Spinner
            android:id="@+id/roomtypespn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>


    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:id="@+id/facilitytxt"
            android:layout_marginTop="20dp"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Facility1"
            android:textSize="30dp"
            tools:layout_editor_absoluteX="56dp"
            tools:layout_editor_absoluteY="60dp" />

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/facility1grp">

            <RadioButton
                android:id="@+id/facility1grpqw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AC" />

            <RadioButton
                android:id="@+id/radioButton2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NON AC" />
        </RadioGroup>


    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:id="@+id/facilitygrp2"
            android:layout_marginTop="20dp"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Facility 2"
            android:textSize="30dp"
            tools:layout_editor_absoluteX="56dp"
            tools:layout_editor_absoluteY="60dp" />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:layout_gravity="center">
            <CheckBox
                android:id="@+id/wifichk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WiFi" />

            <CheckBox
                android:id="@+id/tvchk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TV" />

            <CheckBox
                android:id="@+id/hotwaterchk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hot Water" />
        </LinearLayout>
    </LinearLayout>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_gravity="center">
        <TextView
            android:id="@+id/textView96"
            android:layout_marginTop="20dp"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="No of Beds"
            android:textSize="30dp"
            tools:layout_editor_absoluteX="56dp"
            tools:layout_editor_absoluteY="60dp" />

        <EditText
            android:layout_marginTop="10dp"
            android:id="@+id/noofbedstxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ems="10"
            android:inputType="text"
            android:text="" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_gravity="center">
        <Button
            android:id="@+id/addbtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="5dp"
            android:text="Add "
            tools:layout_editor_absoluteX="27dp"
            tools:layout_editor_absoluteY="140dp" />
        <Button
            android:id="@+id/cancelbtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="5dp"
            android:text="Cancel"
            tools:layout_editor_absoluteX="27dp"
            tools:layout_editor_absoluteY="140dp" />

    </LinearLayout>
</LinearLayout>